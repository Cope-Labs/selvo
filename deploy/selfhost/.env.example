# selvo self-hosted environment.
# Copy to .env, fill in the required values, then `docker compose up -d`.
# Anything left blank or commented out is opt-in.

# ── Required ─────────────────────────────────────────────────────────────────

# Random 32+ byte hex string. Used to sign API key issuance and dashboard
# session cookies. Generate with:  python -c 'import secrets; print(secrets.token_hex(32))'
# CRITICAL: change this from any default and never commit it.
SELVO_API_SECRET=

# ── Strongly recommended ─────────────────────────────────────────────────────

# Free at https://nvd.nist.gov/developers/request-an-api-key
# Without it, NVD enforces a 5 req / 30 s rate limit and CVSS enrichment is
# limited to the top-EPSS 15 CVEs per scan. With it, every CVE is enriched.
NVD_API_KEY=

# GitHub personal access token with public_repo scope. Used to look up upstream
# repos for fix references and to query PoC-in-GitHub for exploit detection.
# Without it: those features are silently disabled.
GITHUB_TOKEN=

# ── Optional: error tracking ─────────────────────────────────────────────────

# Sentry DSN. Without it, errors are logged to stdout only.
# SENTRY_DSN=https://...@sentry.io/...

# ── Optional: paid plans (Stripe) ────────────────────────────────────────────

# Only needed if you want to charge for paid tiers via Stripe Checkout.
# Free / open self-host can leave all of these blank — the dashboard works
# fine, paid-plan upgrade buttons just won't fire.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_WEBHOOK_ENDPOINT_ID=
# STRIPE_PRO_MONTHLY_PRICE_ID=
# STRIPE_PRO_ANNUAL_PRICE_ID=
# STRIPE_ENT_MONTHLY_PRICE_ID=
# JSON map: {"price_id": {"plan": "pro", "interval": "month"}, ...}
# STRIPE_PRICE_MAP={}

# ── Optional: AI features ────────────────────────────────────────────────────

# OpenRouter API key for LLM-summarised changelogs (analysis/changelog.py).
# Without it: changelog summaries are skipped silently.
# OPENROUTER_API_KEY=
